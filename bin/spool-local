#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd -P)
SPOOL_CONFIG="$REPO_ROOT/.spool/config.toml"

if [ ! -f "$SPOOL_CONFIG" ]; then
  echo "error: expected project Spool config not found at $SPOOL_CONFIG" >&2
  echo "hint: run this wrapper from a repository with .spool/config.toml initialized" >&2
  exit 78
fi

cd "$REPO_ROOT"
exec cargo run --manifest-path "$REPO_ROOT/Cargo.toml" -p spool-cli --bin spool -- --config "$SPOOL_CONFIG" "$@"
