.ref
/target/

# Historical pre-rename local state. Kept ignored only so old Tasker
# dogfood artifacts do not become accidental source files during audits.
/.tasker/*
!/.tasker/bootstrap-tasks/
/.tasker/bootstrap-tasks/*
!/.tasker/bootstrap-tasks/TEMPLATE.md

/.spool/*
!/.spool/bootstrap-tasks/
/.spool/bootstrap-tasks/*
!/.spool/bootstrap-tasks/TEMPLATE.md
!/.spool/validation-commands.txt

# extension deps
/extensions/*/node_modules/
